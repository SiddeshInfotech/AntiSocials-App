generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AuthMethod {
  EMAIL
  PHONE
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum WalletTransactionType {
  TASK_COMPLETION
  PURCHASE
  DEDUCTION
}

enum LifeCircleParameter {
  AWARENESS
  ATTENTION
  BODY
  EMOTIONAL
  CONNECTION
  COURAGE
  MEANING
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum NotificationType {
  TASK_REMINDER
  TASK_COMPLETED_CONGRATS
  TASK_MISSED_NUDGE
  STREAK_BROKEN
  STREAK_RECOVERY_NUDGE
  STREAK_RESTORED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model User {
  id                String   @id @default(uuid())
  email             String?  @unique
  phone             String?  @unique
  passwordHash      String?
  timezone          String   @default("UTC")
  name              String?
  username          String?  @unique
  profilePhoto      String?
  profession        String?
  about             String?
  interests         String[] @default([])
  isProfileComplete Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  authIdentities     AuthIdentity[]
  wallet             UserWallet?
  streak             UserStreak?
  lifeCircleScores   LifeCircleScore[]
  dailyTasks         UserDailyTask[]
  deviceTokens       UserDeviceToken[]
  notificationEvents NotificationEvent[]
  communityMembers   CommunityMember[]
  ownedCommunities   Community[]         @relation(name: "CommunityOwner")

  @@index([createdAt])
  @@index([interests])
}

model Community {
  id          String    @id @default(uuid())
  title       String
  description String?
  category    String // Maps to interests e.g., "Volunteering"
  date        DateTime?
  location    String?
  maxMembers  Int?
  ownerId     String
  createdAt   DateTime  @default(now())

  owner   User              @relation(name: "CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members CommunityMember[]

  @@index([category])
}

model CommunityMember {
  id          String   @id @default(uuid())
  userId      String
  communityId String
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId]) // A user can only join a specific community once
}

model AuthIdentity {
  id         String     @id @default(uuid())
  userId     String
  method     AuthMethod
  isVerified Boolean    @default(true)
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, method])
}

model OTPVerification {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone, createdAt])
  @@index([phone, isUsed])
}

model Task {
  id                        String              @id @default(uuid())
  title                     String
  description               String?
  actionType                String?
  level                     Int
  difficulty                TaskDifficulty      @default(MEDIUM)
  parameter                 LifeCircleParameter
  points                    Int
  requiresSubtask           Boolean             @default(false)
  requiresPhotoVerification Boolean             @default(false)
  isActive                  Boolean             @default(true)
  createdAt                 DateTime            @default(now())

  userDailyTasks UserDailyTask[]
  subtasks       Subtask[]

  @@index([parameter, level])
}

model Subtask {
  id          String   @id @default(uuid())
  taskId      String
  title       String
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  task            Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskCompletions UserTaskCompletion[]

  @@index([taskId, isActive])
}

model UserDailyTask {
  id           String     @id @default(uuid())
  userId       String
  taskId       String
  assignedDate DateTime
  status       TaskStatus @default(PENDING)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Restrict)

  completion         UserTaskCompletion?
  notificationEvents NotificationEvent[]

  @@unique([userId, taskId, assignedDate])
  @@index([userId, assignedDate])
}

model UserTaskCompletion {
  id              String    @id @default(uuid())
  userDailyTaskId String    @unique
  subtaskId       String?
  pointsEarned    Int
  photoBase64     String?
  photoUploadedAt DateTime?
  completedAt     DateTime  @default(now())

  userDailyTask UserDailyTask @relation(fields: [userDailyTaskId], references: [id], onDelete: Cascade)
  subtask       Subtask?      @relation(fields: [subtaskId], references: [id], onDelete: SetNull)
}

model UserWallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  balance     Int      @default(0)
  totalEarned Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String
  type        WalletTransactionType
  amount      Int
  description String?
  createdAt   DateTime              @default(now())

  wallet UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
}

model UserStreak {
  id                    String    @id @default(uuid())
  userId                String    @unique
  currentStreak         Int       @default(0)
  bestStreak            Int       @default(0)
  currentMonthStreak    Int       @default(0)
  bestMonthStreak       Int       @default(0)
  currentYearStreak     Int       @default(0)
  bestYearStreak        Int       @default(0)
  monthKey              String?
  yearKey               Int?
  journeyDay            Int       @default(1)
  cycleDay              Int       @default(1)
  journeyStartDate      DateTime  @default(now())
  currentLevelStartDate DateTime  @default(now())
  completedTaskCount    Int       @default(0)
  currentLevel          Int       @default(1)
  isInRecovery          Boolean   @default(false)
  recoverySourceStreak  Int?
  recoveryCompletedDays Int       @default(0)
  lastBreakDate         DateTime?
  lastActivityDate      DateTime?
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LifeCircleScore {
  id               String              @id @default(uuid())
  userId           String
  parameter        LifeCircleParameter
  score            Int                 @default(0)
  lastActivityDate DateTime?
  updatedAt        DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, parameter])
  @@index([userId, lastActivityDate])
}

model UserDeviceToken {
  id         String         @id @default(uuid())
  userId     String
  token      String         @unique
  platform   DevicePlatform
  isActive   Boolean        @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model NotificationEvent {
  id              String             @id @default(uuid())
  userId          String
  userDailyTaskId String?
  type            NotificationType
  title           String
  body            String
  scheduledAt     DateTime
  sentAt          DateTime?
  status          NotificationStatus @default(PENDING)
  retryCount      Int                @default(0)
  lastError       String?
  idempotencyKey  String             @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userDailyTask UserDailyTask? @relation(fields: [userDailyTaskId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([userId, type])
}
