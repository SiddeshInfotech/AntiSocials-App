              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Verify OTP status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.accessToken) {",
                  "  pm.environment.set('token', json.data.accessToken);",
                  "}",
                  "if (json && json.data && typeof json.data.isNewUser !== 'undefined') {",
                  "  pm.environment.set('isNewUser', String(json.data.isNewUser));",
                  "}",
                  "if (json && json.data && typeof json.data.isProfileComplete !== 'undefined') {",
                  "  pm.environment.set('isProfileComplete', String(json.data.isProfileComplete));",
                  "}"
                ]
              }
            }
          ]
        },
