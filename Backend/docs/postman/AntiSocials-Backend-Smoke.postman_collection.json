            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Today tasks status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Today tasks success true', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "if (json && Array.isArray(json.data) && json.data.length > 0) {",
                  "  pm.environment.set('taskId', json.data[0].id);",
                  "}",
                  "var subtaskTask = null;",
                  "if (json && Array.isArray(json.data)) {",
                  "  for (var i = 0; i < json.data.length; i++) {",
                  "    var t = json.data[i];",
                  "    if (t && t.task && (t.task.requiresSubtask || t.task.requiresPhotoVerification)) {",
                  "      subtaskTask = t;",
                  "      break;",
                  "    }",
                  "  }",
                  "}",
                  "if (subtaskTask) {",
                  "  pm.environment.set('taskIdWithRequirements', subtaskTask.id);",
                  "}"
                ]
              }
            }
          ]
        },
